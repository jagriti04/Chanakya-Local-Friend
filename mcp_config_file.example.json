{
  "mcpServers": {
    "mcp_websearch": {
      "command": "uvx",
      "args": [
        "duckduckgo-mcp-server",
        "--transport",
        "stdio"
      ],
      "transport": "stdio",
      "env": {}
    },
    "mcp_fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ],
      "transport": "stdio",
      "env": {}
    },
    "mcp_calculator": {
      "command": "uvx",
      "args": [
        "calculator-mcp-server"
      ],
      "transport": "stdio",
      "env": {}
    },
    "mcp_code_execution": {
      "command": "python",
      "args": [
        "-m",
        "chanakya.services.mcp_sandbox_exec_server"
      ],
      "transport": "stdio",
      "env": {}
    }
  }
}
