# OpenAI / LM Studio settings
HOST_AGENT_MODES="local,a2a"
DEFAULT_HOST_AGENT_MODE="local"
CORE_AGENT_BACKEND="local"
DEFAULT_CORE_AGENT_TARGET="default"
OPENAI_BASE_URL="http://127.0.0.1:1234/v1"
OPENAI_CHAT_MODEL_ID="your-core-agent-model"
OPENAI_API_KEY="your-api-key"
A2A_AGENT_URL="http://127.0.0.1:18770"
OPENCODE_BASE_URL="http://127.0.0.1:18496"
OPENAI_COMPATIBLE_TARGETS_JSON='[{"key":"default","label":"Local OpenAI-Compatible","description":"Configured OpenAI-compatible endpoint.","base_url":"http://127.0.0.1:1234/v1","model":"your-core-agent-model"}]'
A2A_TARGETS_JSON='[{"key":"opencode","label":"OpenCode A2A","description":"Local OpenCode bridge exposed over A2A.","url":"http://127.0.0.1:18770","opencode_http_url":"http://127.0.0.1:18496","continuity_strategy":"seeded_history","default_remote_agent":"build"}]'

# Conversation-layer orchestration settings
CONVERSATION_ORCHESTRATION_MODE="auto_fallback"
CONVERSATION_OPENAI_BASE_URL="http://127.0.0.1:1234/v1"
CONVERSATION_OPENAI_CHAT_MODEL_ID="your-conversation-layer-model"
CONVERSATION_OPENAI_API_KEY="your-api-key"

# Long-term profile memory is enabled automatically when requests include metadata.profile_id.
# Slow filler/presence now comes from measured latency in real delayed operations; there is no env toggle for the old simulated delay path.
CHANAKYA_DEBUG=true
DATABASE_URL="sqlite:////absolute/path/to/chanakya.db"
AGENT_DATABASE_URL="sqlite:////absolute/path/to/agent.db"
CONVERSATION_DATABASE_URL="sqlite:////absolute/path/to/conversation.db"

# Conversation working-memory store
CONVERSATION_STATE_STORE_BACKEND="redis"
CONVERSATION_STATE_STORE_REDIS_URL="redis://127.0.0.1:6387/0"
CONVERSATION_STATE_STORE_REDIS_KEY_PREFIX="conversation:working-memory:"
CONVERSATION_STATE_STORE_TTL_SECONDS="86400"

# Local Redis container settings used by start_stack.sh / stop_stack.sh
REDIS_CONTAINER_NAME="chanakya-redis"
REDIS_IMAGE="redis:7-alpine"
REDIS_HOST_PORT="6387"
REDIS_CONTAINER_PORT="6379"
